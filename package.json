{
  "name": "yard",
  "version": "0.0.1",
  "license": "MIT",
  "bin": {
    "yard": "./dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "node --watch src/bin.ts",
    "build:bundle": "vp pack",
    "start": "node dist/bin.mjs",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run",
    "prepare": "effect-tsgo patch && vp config --no-agent"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.93",
    "effect": "^4.0.0-beta.93"
  },
  "devDependencies": {
    "@effect/tsgo": "^0.16.0",
    "@effect/vitest": "4.0.0-beta.93",
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260703.1",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=24"
  }
}
